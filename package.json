{
  "name": "hp-12c-calculator",
  "version": "1.5.0",
  "description": "HP-12C Financial Calculator Web Implementation",
  "main": "js/calculator.js",
  "scripts": {
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:verbose": "jest --verbose",
    "test:financial": "jest tests/financial.test.js",
    "test:tvm": "jest tests/tvm.test.js",
    "test:percentage": "jest tests/percentage.test.js"
  },
  "keywords": [
    "calculator",
    "financial",
    "hp-12c",
    "tvm",
    "npv",
    "irr"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "jest": "^29.7.0"
  },
  "jest": {
    "testEnvironment": "node",
    "coverageDirectory": "coverage",
    "collectCoverageFrom": [
      "js/**/*.js",
      "!js/keyboard.js",
      "!js/key-info.js"
    ],
    "testMatch": [
      "**/tests/**/*.test.js"
    ],
    "verbose": true
  }
}
